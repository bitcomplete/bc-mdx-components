{
  "name": "@bitcomplete/mdx-components",
  "version": "0.2.1",
  "description": "MDX components for agent-generated documents: plans, reports, session summaries. Static HTML output with Agentic Craft visuals, no React runtime needed in the browser.",
  "keywords": [
    "mdx",
    "components",
    "agent",
    "llm",
    "static-site"
  ],
  "license": "MIT",
  "author": "Bit Complete",
  "homepage": "https://github.com/bitcomplete/bc-mdx-components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcomplete/bc-mdx-components.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bundle": "./dist/bundle.iife.global.js",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:css": "tailwindcss -i src/styles/tailwind.css -o dist/styles.css --minify && node scripts/embed-css.mjs",
    "build:manifest": "node scripts/extract-manifest.mjs",
    "build:js": "tsup",
    "build": "pnpm run build:manifest && pnpm run build:css && pnpm run build:js",
    "dev": "pnpm run build:manifest && pnpm run build:css && tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "[ -d dist ] || pnpm run build",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@mdx-js/mdx": "^3.1.0",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "ts-morph": "^28.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
