{
  "name": "@bitcomplete/mdx-components",
  "version": "0.1.0",
  "description": "MDX components for agent-generated documents: plans, reports, session summaries. Static HTML output, no React runtime needed in the browser.",
  "keywords": [
    "mdx",
    "components",
    "agent",
    "llm",
    "static-site"
  ],
  "license": "MIT",
  "author": "Bit Complete",
  "homepage": "https://github.com/bitcomplete/bc-mdx-components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcomplete/bc-mdx-components.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bundle": "./dist/bundle.iife.global.js",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "[ -d dist ] || pnpm run build",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "preact": "^10.25.0",
    "preact-render-to-string": "^6.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
